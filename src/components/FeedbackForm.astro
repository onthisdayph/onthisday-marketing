---
const formUrl = import.meta.env.PUBLIC_FEEDBACK_FORM_ENDPOINT;
---

<section class="py-20 sm:py-28 bg-gray-50">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="animate-on-scroll">
      <p class="text-sm font-bold text-ph-blue uppercase tracking-widest mb-3">Recommendations</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Got a recommendation?</h2>
      <p class="text-lg text-gray-600 max-w-xl mx-auto mb-3">
        You just read about a platform built to keep Philippine history honest and accessible.
        If something came to mind — a gap we should fill, a feature worth building, or a community we should reach — we want to hear it.
      </p>
      <p class="text-base text-gray-500 max-w-lg mx-auto mb-10">
        Every recommendation gets read by the team. No idea is too small.
      </p>

      {formUrl ? (
        <a
          href={formUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-ph-blue text-white font-bold px-8 py-4 rounded-lg text-lg hover:bg-ph-blue-dark transition-colors"
        >
          Share a Recommendation
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
      ) : (
        <p class="text-sm text-gray-400">
          Set <code class="bg-gray-100 px-1.5 py-0.5 rounded text-ph-blue font-mono">PUBLIC_FEEDBACK_FORM_ENDPOINT</code> to enable this link.
        </p>
      )}
    </div>
  </div>
</section>
