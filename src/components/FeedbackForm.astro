---
const formEndpoint = import.meta.env.PUBLIC_FEEDBACK_FORM_ENDPOINT;
---

<section class="py-20 sm:py-28 bg-gray-50">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 animate-on-scroll">
      <p class="text-sm font-bold text-ph-blue uppercase tracking-widest mb-3">Feedback</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Help Us Improve</h2>
      <p class="text-lg text-gray-600">
        Found missing history? Have a suggestion? We want to hear from you.
      </p>
    </div>

    {formEndpoint ? (
      <form
        action={formEndpoint}
        method="POST"
        class="gradient-border-card p-8 animate-on-scroll"
      >
        <div class="mb-5">
          <label for="feedback-name" class="block text-sm font-semibold text-gray-700 mb-1.5">
            Name <span class="text-gray-400 font-normal">(optional)</span>
          </label>
          <input
            id="feedback-name"
            type="text"
            name="name"
            placeholder="Juan dela Cruz"
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-ph-blue focus:border-transparent transition"
          />
        </div>

        <div class="mb-5">
          <label for="feedback-email" class="block text-sm font-semibold text-gray-700 mb-1.5">
            Email <span class="text-gray-400 font-normal">(optional — for follow-up)</span>
          </label>
          <input
            id="feedback-email"
            type="email"
            name="email"
            placeholder="juan@example.com"
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-ph-blue focus:border-transparent transition"
          />
        </div>

        <div class="mb-5">
          <label for="feedback-type" class="block text-sm font-semibold text-gray-700 mb-1.5">
            Type
          </label>
          <select
            id="feedback-type"
            name="type"
            required
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 focus:outline-none focus:ring-2 focus:ring-ph-blue focus:border-transparent transition bg-white"
          >
            <option value="" disabled selected>Select a category</option>
            <option value="missing-event">Missing historical event</option>
            <option value="incorrect-info">Incorrect information</option>
            <option value="feature-request">Feature request</option>
            <option value="bug-report">Bug report</option>
            <option value="general">General feedback</option>
          </select>
        </div>

        <div class="mb-7">
          <label for="feedback-message" class="block text-sm font-semibold text-gray-700 mb-1.5">
            Message <span class="text-ph-red">*</span>
          </label>
          <textarea
            id="feedback-message"
            name="message"
            rows="5"
            required
            placeholder="Share your feedback, correction, or suggestion..."
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-ph-blue focus:border-transparent transition resize-y"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-ph-blue text-white font-bold px-6 py-3 rounded-lg hover:bg-ph-blue-dark transition-colors"
        >
          Send Feedback
        </button>
      </form>
    ) : (
      <div class="gradient-border-card p-8 text-center text-gray-500 animate-on-scroll">
        <p class="font-semibold text-gray-700 mb-1">Feedback form not configured.</p>
        <p class="text-sm">Set <code class="bg-gray-100 px-1.5 py-0.5 rounded text-ph-blue font-mono">PUBLIC_FEEDBACK_FORM_ENDPOINT</code> in your environment to enable this form.</p>
      </div>
    )}
  </div>
</section>
