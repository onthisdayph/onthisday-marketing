---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout
  title="Blog"
  description="Articles about Philippine history, civic tech, and the fight against historical revisionism."
>
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 mb-4">Blog</h1>
      <p class="text-lg text-gray-600 mb-12">
        Articles about Philippine history, civic tech, and the fight against historical revisionism.
      </p>

      {posts.length === 0 ? (
        <p class="text-gray-500 text-center py-12">No posts yet. Check back soon!</p>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id}
            />
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
