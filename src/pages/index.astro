---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import MemeShowcase from '../components/MemeShowcase.astro';
import FeatureCard from '../components/FeatureCard.astro';
import FAQ from '../components/FAQ.astro';
import CTASection from '../components/CTASection.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
---

<BaseLayout
  title="OnThisDay.PH — Resibo ng Bayan"
  description="Philippine history in meme format with verified sources. Remember what happened. Hold leaders accountable."
>
  <Hero />

  <!-- Problem Statement -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <p class="text-sm font-bold text-ph-blue uppercase tracking-widest mb-3">The Problem</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
          Important moments get forgotten.
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          History is rewritten, milestones fade, and the events that shaped the nation get lost in the noise.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="gradient-border-card p-6 text-center flex flex-col h-full animate-on-scroll">
          <div class="w-14 h-14 mx-auto mb-4 bg-gray-100 rounded-xl flex items-center justify-center">
            <svg class="w-7 h-7 text-gray-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182" /></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Revisionism Spreads</h3>
          <p class="text-gray-600 text-sm flex-1">Historical facts are twisted or erased on social media, misleading millions of Filipinos.</p>
        </div>
        <div class="gradient-border-card p-6 text-center flex flex-col h-full animate-on-scroll-delay-1">
          <div class="w-14 h-14 mx-auto mb-4 bg-gray-100 rounded-xl flex items-center justify-center">
            <svg class="w-7 h-7 text-gray-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m5.231 13.481L15 17.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v16.5c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9zm3.75 11.625a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Sources Are Scattered</h3>
          <p class="text-gray-600 text-sm flex-1">Verified records exist across dozens of sites. No single place brings them together.</p>
        </div>
        <div class="gradient-border-card p-6 text-center flex flex-col h-full animate-on-scroll-delay-2">
          <div class="w-14 h-14 mx-auto mb-4 bg-gray-100 rounded-xl flex items-center justify-center">
            <svg class="w-7 h-7 text-gray-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Memory Fades</h3>
          <p class="text-gray-600 text-sm flex-1">Each generation forgets. Without accessible records, accountability disappears.</p>
        </div>
      </div>
    </div>
  </section>

  <HowItWorks />
  <MemeShowcase />

  <!-- Features Grid -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <p class="text-sm font-bold text-ph-blue uppercase tracking-widest mb-3">Features</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Everything You Need</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Built for civic engagement, designed for shareability.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="animate-on-scroll">
          <FeatureCard
            title="Timeline Feed"
            description="Browse Philippine history day by day. See what happened on this day — from politics to sports to culture."
          >
            <svg slot="icon" class="w-6 h-6 text-ph-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
          </FeatureCard>
        </div>
        <div class="animate-on-scroll-delay-1">
          <FeatureCard
            title="Community Voting"
            description="Upvote the most important events. The community decides what matters most."
          >
            <svg slot="icon" class="w-6 h-6 text-ph-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.633 10.5c.806 0 1.533-.446 2.031-1.08a9.041 9.041 0 012.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 00.322-1.672V3a.75.75 0 01.75-.75A2.25 2.25 0 0116.5 4.5c0 1.152-.26 2.243-.723 3.218-.266.558.107 1.282.725 1.282h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 01-2.649 7.521c-.388.482-.987.729-1.605.729H14.23c-.483 0-.964-.078-1.423-.23l-3.114-1.04a4.501 4.501 0 00-1.423-.23H5.904M14.25 9h2.25M5.904 18.75c.083.205.173.405.27.602.197.4-.078.898-.523.898h-.908c-.889 0-1.713-.518-1.972-1.368a12 12 0 01-.521-3.507c0-1.553.295-3.036.831-4.398C3.387 10.203 4.167 9.75 5 9.75h1.053c.472 0 .745.556.5.96a8.958 8.958 0 00-1.302 4.665c0 1.194.232 2.333.654 3.375z" /></svg>
          </FeatureCard>
        </div>
        <div class="animate-on-scroll-delay-2">
          <FeatureCard
            title="Source Verification"
            description="Every entry requires linked sources. No fake news, no revisionism — just facts."
          >
            <svg slot="icon" class="w-6 h-6 text-ph-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" /></svg>
          </FeatureCard>
        </div>
        <div class="animate-on-scroll">
          <FeatureCard
            title="Search & Discover"
            description="Search by person, date, or event. Find the receipts you need in seconds."
          >
            <svg slot="icon" class="w-6 h-6 text-ph-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" /></svg>
          </FeatureCard>
        </div>
        <div class="animate-on-scroll-delay-1">
          <FeatureCard
            title="Easy Sharing"
            description="Share meme-format history cards on social media. Make history go viral."
          >
            <svg slot="icon" class="w-6 h-6 text-ph-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z" /></svg>
          </FeatureCard>
        </div>
        <div class="animate-on-scroll-delay-2">
          <FeatureCard
            title="Free for Everyone"
            description="Built by Filipinos, for Filipinos. No paywalls, no premium tiers. History belongs to everyone."
          >
            <svg slot="icon" class="w-6 h-6 text-ph-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>
          </FeatureCard>
        </div>
      </div>
    </div>
  </section>

  <FAQ />
  <FeedbackForm />
  <CTASection />
</BaseLayout>
